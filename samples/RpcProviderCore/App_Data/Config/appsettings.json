{
    "Logging": {
        "LogLevel": {
            "Default": "Debug"
        }
    },
    "AllowedHosts": "*",
    "Kestrel": {
        "EndpointDefaults": {
            "Protocols": "Http2"
        }
    },
    "Otel": {
        "Otlp": {
            "Endpoint": "",
            "Protocol": "Grpc"
        },
        "TraceSourceFilter": [ "Zooyard.Rpc" ],
        "Exporter": {
            "Tracing": "Console",
            "Metrics": "Console",
            "Log": "Console"
        }
    }
}
